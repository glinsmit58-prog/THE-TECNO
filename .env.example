# =============================================================
# TecnoGems — .env.example
# نسخ هذا الملف إلى .env وتعبئة القيم الحقيقية
# cp .env.example .env
# =============================================================

# ----- أمان (مطلوب في الإنتاج) -----
# أنشئه بـ: python -c "import secrets; print(secrets.token_urlsafe(48))"
# V50.2 LOW: اترك هذا الحقل فارغاً حتى لا يُستخدم نص افتراضي بالخطأ في الإنتاج.
# التطبيق يرفض الإقلاع في الإنتاج إذا كانت القيمة فارغة أو هي النص الافتراضي.
SECRET_KEY=

# dev | production
FLASK_ENV=development

# ----- الموقع -----
BASE_URL=https://tecnogems.com

# ----- مدة الجلسة (بالأيام) — V50.2 خُفِّضت من 14 إلى 7 -----
SESSION_LIFETIME_DAYS=7

# ----- حساب الأدمن الافتراضي -----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<CHANGE-THIS-STRONG-PASSWORD>

# ----- البريد الإلكتروني (اختياري — للتحقق من الحساب واستعادة كلمة المرور) -----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
# Gmail: استخدم App Password (16 حرف) وليس كلمة مرور الحساب
MAIL_PASSWORD=
MAIL_FROM=your-email@gmail.com

# ----- Google OAuth (اختياري) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://tecnogems.com/auth/google/callback

# ----- Redis / RQ (إلزامي في الإنتاج — لـ rate-limiting + background jobs) -----
REDIS_URL=redis://localhost:6379/0

# ----- V52 (task D): الرصد والتسجيل المنظَّم -----
# كل المتغيرات اختيارية. عدم تحديدها يعني الإبقاء على السلوك السابق
# (logging نصّي عادي + لا إرسال إلى Sentry).

# إذا حدَّدت DSN، سيُفعَّل sentry-sdk تلقائياً لاستقبال الأخطاء.
# SENTRY_DSN=https://<public_key>@<org>.ingest.sentry.io/<project>

# نسبة العيّنات للـ APM tracing. 0 = لا tracing (الافتراضي). استخدم 0.1 في الإنتاج
# للبدء. قيم أعلى تعني تكلفة أكبر على Sentry plan.
# SENTRY_TRACES_SAMPLE_RATE=0

# وسم البيئة في Sentry (افتراضياً يأخذ FLASK_ENV).
# SENTRY_ENVIRONMENT=production

# وسم الإصدار اختياري — مفيد لربط الأخطاء بـ git commit/tag.
# SENTRY_RELEASE=v52.0

# فعِّل لكتابة سجلّات JSON سطراً بسطر (بدل النصّ العادي). مفيد عند استخدام
# log aggregators (Datadog, Loki, CloudWatch Logs). القيم المقبولة: 1/true/yes/on.
# LOG_JSON=1


# ----- V53: Backup (S3/R2) -----
# R2 bucket name (required for backup/restore scripts)
BACKUP_S3_BUCKET=tecnogems-backups

# Cloudflare R2 endpoint (leave empty for AWS S3)
BACKUP_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# AWS credentials (used by aws CLI for R2/S3 access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto

# Healthchecks.io ping URL (optional — alerts if backup misses a run)
# BACKUP_HEARTBEAT_URL=https://hc-ping.com/<uuid>
